generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Alunos{
  id Int @id @default(autoincrement())
  name String
  idade Int
  cpf Int @unique
  email String @unique 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  curso Cursos[]
}

model Cursos{
  id Int @id @default(autoincrement())
  nome String @unique
  professor String?
  cargaHoraria Int
  descricao String?
  aluno Alunos[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
