generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Alunos {
  id    Int    @id @default(autoincrement())
  name String @unique
  idade Int 
  cpf Int @unique
  email String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 